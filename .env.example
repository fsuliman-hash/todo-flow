# Copy to .env for local development (never commit real .env).
# `node server.js` loads this file automatically (same folder as server.js). Restart after edits.

# Anthropic — server only (required for chat + chat-action)
CLAUDE_API_KEY=
# Optional override; otherwise the server tries common Sonnet IDs in order
CLAUDE_MODEL=

# Supabase — injected into the browser via /runtime-config.js (anon key is public; protect data with RLS)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# If the frontend is hosted on a different origin than the API (e.g. static site + Vercel functions),
# set the API origin (no trailing slash). Leave EMPTY for normal local use with `node server.js` (use relative /api/chat).
# If you set http://127.0.0.1:5500 here, open the app at 127.0.0.1 — not localhost (different origins).
PUBLIC_API_BASE=

# Only used by Vercel `api/*.js` — ignored by `server.js`. Optional for local .env.
ALLOWED_ORIGIN=

# Server bind (optional)
# HOST=127.0.0.1
# PORT=5500
