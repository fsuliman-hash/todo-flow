{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "functions": {
    "api/chat.js": { "maxDuration": 30 },
    "api/chat-action.js": { "maxDuration": 30 },
    "api/chat-edit.js": { "maxDuration": 30 },
    "api/chat-categorize.js": { "maxDuration": 30 },
    "api/chat-shift.js": { "maxDuration": 30 },
    "api/chat-shift-intent.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
